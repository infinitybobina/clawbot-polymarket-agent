# =============================================================================
# ClawBot — все переменные окружения в одном файле
# =============================================================================
# Скопируйте в .env и заполните значения. Файл .env не коммитится в git.
#   Windows: copy .env.example .env
#   Linux/macOS: cp .env.example .env
#
# Подробности: ENV.md. Источники: OBSERVABILITY.md, PRODUCTION_READY.md,
# analytics/README.md, analytics/config/analytics.env.example, код бота.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram (обязательно для отчётов main.py / main_v2.py)
# -----------------------------------------------------------------------------
# OBSERVABILITY.md: «Нужны TELEGRAM_TOKEN и TELEGRAM_CHAT_ID в .env»
# Токен бота от @BotFather; chat_id — куда слать сводки (число или строка).
TELEGRAM_TOKEN=https://api.telegram.org/bot8601615067:AAFO9lCQsqW4UBb6m7ohOwYyzI1kFTK6S2s/getUpdates
TELEGRAM_CHAT_ID=@ClawBotTrader_bot

# -----------------------------------------------------------------------------
# OpenAI / LLM (обязательно для стратегии с LLM)
# -----------------------------------------------------------------------------
# strategy.py: api_key = os.getenv("OPENAI_API_KEY"); при отсутствии — ValueError.
# run_test_a_llm_table.py, simple_test.py, test_api.py — тот же ключ.
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# База данных (опционально)
# -----------------------------------------------------------------------------
# trade_logger.py: запись сделок в trades. analytics: те же данные для отчётов.
# analytics/README.md: «Строка подключения к Postgres (та же БД, что у бота)»
# Пример: postgres://user:password@localhost:5432/clawbot
DATABASE_URL=

# -----------------------------------------------------------------------------
# Версионирование конфига (опционально)
# -----------------------------------------------------------------------------
# trade_logger.py: пишет в trades.config_version; аналитика фильтрует по нему.
# analytics/README.md: «Должна совпадать с CONFIG_VERSION в .env бота»
CONFIG_VERSION=2026-03-05_15m_conservative_v3
# Альтернатива, если бот пишет по хешу: CONFIG_HASH (trade_logger.py).
# CONFIG_HASH=

# -----------------------------------------------------------------------------
# Идентификатор стратегии (опционально)
# -----------------------------------------------------------------------------
# trade_logger.py: strategy_id or os.environ.get("STRATEGY_ID", "LLM_CRYPTO_15M")
# analytics/README.md: «Идентификатор стратегии, например LLM_CRYPTO_15M»
STRATEGY_ID=LLM_CRYPTO_15M

# -----------------------------------------------------------------------------
# Аналитика: счётчик закрытых сделок (опционально)
# -----------------------------------------------------------------------------
# analytics/check_closed_trades.py: при closed_trades >= THRESHOLD выводит
# THRESHOLD_REACHED и при заданных TELEGRAM_* шлёт уведомление. По умолчанию 30.
# analytics/README.md: «Порог для check_closed_trades.py (по умолчанию 30)»
CHECK_CLOSED_TRADES_THRESHOLD=30

# -----------------------------------------------------------------------------
# Аналитика: ноутбуки и отчёты (опционально)
# -----------------------------------------------------------------------------
# analytics/README.md: «Таймзона для группировок по времени (в SQL по умолчанию UTC)»
ANALYTICS_TIMEZONE=UTC
# analytics/README.md: «Лимит строк для отчёта (0 = без лимита)»
MAX_TRADES_FOR_REPORT=0
# analytics/README.md: «Выводить ли графики интерактивно (true/false)»
SHOW_PLOTS=true

# -----------------------------------------------------------------------------
# Live-торговля (на будущее)
# -----------------------------------------------------------------------------
# PRODUCTION_READY.md: «Ключи и секреты только в .env»; «ключи CLOB в .env»
# До реализации live_trader.py не используются.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
