# === Database connection ===
# Полная строка подключения к той же БД, что использует ClawBot.
# Пример для Postgres:
# postgres://user:password@localhost:5432/clawbot
DATABASE_URL=postgres://user:password@localhost:5432/clawbot

# === Strategy / config versioning ===
# Версия стратегии/конфига, по которой строим отчёты.
# Должна совпадать с CONFIG_VERSION в .env бота,
# чтобы trades.config_version фильтровался единообразно.
CONFIG_VERSION=2026-03-05_15m_conservative_v3

# Идентификатор стратегии (совпадает с тем, что пишет бот в trades.strategy_id).
# Например: LLM_CRYPTO_15M, LLM_POLITICS_1H и т.п.
STRATEGY_ID=LLM_CRYPTO_15M

# === Analytics runtime options (опционально) ===
# Таймзона для агрегаций по датам/часам (например, при группировке по часу входа).
# Используется в ноутбуках при необходимости.
ANALYTICS_TIMEZONE=UTC

# Лимиты для выборок (на случай очень большой таблицы trades).
# Если пусто или 0 — не ограничивать.
MAX_TRADES_FOR_REPORT=0

# === Plotting options (опционально) ===
# Включать ли отображение графиков интерактивно в ноутбуке.
# Если "false" — ноутбук может сохранять только PNG/HTML без показа.
SHOW_PLOTS=true
